{
  "name": "turklion-launcher",
  "version": "1.0.0",
  "author": "Ozaii",
  "description": "Turklion Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder && node copy-to-desktop.js",
    "build:win": "electron-builder --win && node copy-to-desktop.js",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.turklion.launcher",
    "productName": "TurklionLauncher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "bundled_packs/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "src/assets/icon.png"
    },
    "portable": {
      "requestExecutionLevel": "user"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "src/assets/icon.png",
      "category": "Game"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "src/assets/icon.png",
      "category": "public.app-category.games",
      "darkModeSupport": true
    }
  },
  "dependencies": {
    "discord-rpc": "^4.0.1"
  }
}

